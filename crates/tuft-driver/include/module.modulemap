module TuftDriver {
    header "tuft.h"
    // The C++ bridge (`tuft-driver-sys/bridge/`) is now baked into the
    // same xcframework as the Rust runtime (build.rs / cc::Build), so
    // its public C ABI is part of the same Swift module. This used to
    // live in a separate `TuftBridge` SPM target.
    header "tuft_bridge.h"
    export *
}
