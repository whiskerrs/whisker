module LyraMobile {
    header "lyra_mobile.h"
    // The C++ bridge (`native/bridge/`) is now baked into the same
    // xcframework as the Rust runtime (build.rs / cc::Build), so its
    // public C ABI is part of the same Swift module. This used to live
    // in a separate `LyraBridge` SPM target.
    header "lyra_bridge.h"
    export *
}
