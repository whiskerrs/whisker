module WhiskerDriver {
    header "whisker.h"
    // The C++ bridge (`whisker-driver-sys/bridge/`) is now baked into the
    // same xcframework as the Rust runtime (build.rs / cc::Build), so
    // its public C ABI is part of the same Swift module. This used to
    // live in a separate `WhiskerBridge` SPM target.
    header "whisker_bridge.h"
    export *
}
