# Rust
target/
**/*.rs.bk

# Coverage (cargo-llvm-cov: HTML lives under target/llvm-cov/, but the
# LCOV file gets written to the repo root unless overridden)
/lcov.info

# IDE
.idea/
.vscode/
*.iml

# OS
.DS_Store
Thumbs.db

# CNG (Continuous Native Generation) output. Android + iOS host
# projects under `examples/<name>/gen/{android,ios}/` are produced by
# `whisker-cng` from each example's `whisker.rs` and must never be
# committed. The whole `gen/` subtree is ignored, including gradle's
# `.gradle/` / `build/` caches that live there during dev.
examples/**/gen/

# Native build artifacts under the workspace's Whisker-internal
# `native/` tree (Lynx AARs, SPM build caches, etc.). These belong to
# the Whisker build, not user projects.
native/android/.gradle/
native/android/build/
native/android/local.properties
native/android/.idea/
native/android/**/build/
native/android/**/.cxx/
native/ios/.build/
native/ios/.swiftpm/
native/ios/*.xcodeproj/
native/ios/*.xcworkspace/
native/bridge/build/

# Per-example Rust workspace artifacts.
examples/**/target/
examples/**/Cargo.lock

.claude/
