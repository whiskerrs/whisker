# Rust
target/
**/*.rs.bk

# IDE
.idea/
.vscode/
*.iml

# OS
.DS_Store
Thumbs.db

# CNG generated outputs (anchored — never matches native/android, native/ios)
/ios/
/android/
/.lyra/
/examples/**/android/
/examples/**/.lyra/

# Per-example iOS host directories are CNG-generated by default, but
# `hello-world` ships a hand-authored shell. Ignore every other
# `examples/*/ios/` (placeholder for future CNG output) but keep
# hello-world's tracked.
/examples/*/ios/
!/examples/hello-world/ios/

# Native build artifacts
native/android/.gradle/
native/android/build/
native/android/local.properties
native/android/.idea/
native/android/**/build/
native/ios/.build/
native/ios/.swiftpm/
native/ios/*.xcodeproj/
native/ios/*.xcworkspace/
native/bridge/build/

# Examples (separate workspaces)
examples/**/target/
examples/**/Cargo.lock

# Generated Xcode artifacts (both `examples/<name>/` directly and the
# more typical `examples/<name>/ios/` host layout)
examples/**/*.xcodeproj/
examples/**/*.xcworkspace/
examples/**/Info.plist
examples/**/build/
examples/**/.build/
examples/**/.swiftpm/
