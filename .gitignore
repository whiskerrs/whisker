# Rust
target/
**/*.rs.bk

# IDE
.idea/
.vscode/
*.iml

# OS
.DS_Store
Thumbs.db

# CNG generated outputs (anchored — never matches native/android, native/ios)
/ios/
/android/
/.tuft/
/examples/**/android/
/examples/**/.tuft/

# Per-example iOS host directories are CNG-generated by default, but
# `hello-world` ships a hand-authored shell. Ignore every other
# `examples/*/ios/` (placeholder for future CNG output) but keep
# hello-world's tracked.
/examples/*/ios/
!/examples/hello-world/ios/

# Same story for Android: every example's android/ host dir is
# CNG-output by default, but hello-world has a hand-authored gradle
# project we need to track.
!/examples/hello-world/android/

# Native build artifacts
native/android/.gradle/
native/android/build/
native/android/local.properties
native/android/.idea/
native/android/**/build/
native/android/**/.cxx/
native/ios/.build/
native/ios/.swiftpm/
native/ios/*.xcodeproj/
native/ios/*.xcworkspace/
native/bridge/build/

# Examples (separate workspaces)
examples/**/target/
examples/**/Cargo.lock

# Android Gradle artifacts inside example projects
examples/**/android/.gradle/
examples/**/android/.idea/
examples/**/android/local.properties
examples/**/android/build/
examples/**/android/**/build/
examples/**/android/**/.cxx/

# jniLibs/<abi>/*.so are dropped in by scripts/build-android-example.sh
# (libhello_world.so from cargo, libc++_shared.so from the NDK sysroot).
examples/**/android/**/jniLibs/

# Generated Xcode artifacts (both `examples/<name>/` directly and the
# more typical `examples/<name>/ios/` host layout)
examples/**/*.xcodeproj/
examples/**/*.xcworkspace/
examples/**/Info.plist
examples/**/build/
examples/**/.build/
examples/**/.swiftpm/
